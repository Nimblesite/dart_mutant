<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HYDK9YZ5CX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-HYDK9YZ5CX');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="{{ description or 'dart_mutant is a mutation testing tool for Dart. It uses tree-sitter AST parsing to generate syntactically valid mutants and runs dart test in parallel.' }}"
    />
    <meta
      name="keywords"
      content="dart mutation testing, dart test quality, dart_mutant, dart AST mutation, tree-sitter dart, mutation score, dart unit testing, Stryker dart"
    />
    <meta name="author" content="Nimblesite" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <title>{{ title or 'dart_mutant' }} | Mutation Testing for Dart</title>

    {% set siteUrl = 'https://dartmutant.dev' %}
    {% set pagePath = page.url or '/' %}
    {% set canonicalUrl = siteUrl + pagePath %}
    {% set ogImage = siteUrl + '/images/og-image.svg' %}
    {% set pageTitle = title or 'dart_mutant' %}
    {% set pageDesc = description or 'dart_mutant is a mutation testing tool for Dart. AST-based mutations that reveal gaps in your test suite.' %}

    <!-- Canonical -->
    <link rel="canonical" href="{{ canonicalUrl }}" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="dart_mutant" />
    <meta property="og:title" content="{{ pageTitle }} | Mutation Testing for Dart" />
    <meta property="og:description" content="{{ pageDesc }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:image" content="{{ ogImage }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="dart_mutant - Mutation Testing for Dart" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }} | Mutation Testing for Dart" />
    <meta name="twitter:description" content="{{ pageDesc }}" />
    <meta name="twitter:image" content="{{ ogImage }}" />
    <meta name="twitter:image:alt" content="dart_mutant - Mutation Testing for Dart" />

    <!-- JSON-LD: SoftwareApplication + Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "SoftwareApplication",
          "name": "dart_mutant",
          "url": "https://dartmutant.dev",
          "description": "A mutation testing tool for Dart. Uses tree-sitter AST parsing to generate syntactically valid mutants and runs dart test against each mutation in parallel.",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Linux, macOS, Windows",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "license": "https://opensource.org/licenses/MIT",
          "programmingLanguage": "Rust",
          "codeRepository": "https://github.com/Nimblesite/dart_mutant",
          "author": {
            "@type": "Organization",
            "name": "Nimblesite",
            "url": "https://nimblesite.co"
          }
        },
        {
          "@type": "Organization",
          "name": "Nimblesite",
          "url": "https://nimblesite.co",
          "logo": "https://dartmutant.dev/images/og-image.svg"
        }
      ]
    }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Orbitron:wght@500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Styles -->
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />

    <!-- Favicon -->
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧬</text></svg>"
    />
  </head>
  <body>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container nav-inner">
        <a href="{{ '/' | url }}" class="nav-logo">
          <span class="nav-logo-icon">🧬</span>
          <span>dart_mutant</span>
        </a>

        <button
          class="nav-toggle"
          aria-label="Toggle navigation"
          onclick="document.querySelector('.nav-links').classList.toggle('active')"
        >
          ☰
        </button>

        <ul class="nav-links">
          <li><a href="{{ '/docs/' | url }}" class="nav-link">Docs</a></li>
          <li><a href="{{ '/docs/operators/' | url }}" class="nav-link">Operators</a></li>
          <li><a href="{{ '/docs/ci/' | url }}" class="nav-link">CI/CD</a></li>
          <li>
            <a
              href="https://github.com/Nimblesite/dart_mutant"
              class="nav-cta"
              target="_blank"
              rel="noopener"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                />
              </svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main Content -->
    <main>{{ content | safe }}</main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-logo">🧬 dart_mutant</div>
          <ul class="footer-links">
            <li><a href="{{ '/docs/' | url }}" class="footer-link">Documentation</a></li>
            <li>
              <a href="https://github.com/Nimblesite/dart_mutant" class="footer-link" target="_blank"
                >GitHub</a
              >
            </li>
            <li>
              <a
                href="https://github.com/Nimblesite/dart_mutant/issues"
                class="footer-link"
                target="_blank"
                >Issues</a
              >
            </li>
            <li><a href="{{ '/docs/contributing/' | url }}" class="footer-link">Contributing</a></li>
          </ul>
        </div>
        <p class="footer-copy">
          MIT License &copy; 2026
          <a href="https://nimblesite.co" class="footer-link" target="_blank" rel="noopener">Nimblesite</a>.
          Built with Rust & tree-sitter. Hunt down every weak test.
        </p>
      </div>
    </footer>

    <script src="{{ '/js/main.js' | url }}" defer></script>
  </body>
</html>
